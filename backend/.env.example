# Cấu hình cổng chạy backend API
PORT=5000

# Cấu hình kết nối Microsoft SQL Server
DB_USER=sa
DB_PASSWORD=YourStrongPassword123
DB_SERVER=localhost
DB_NAME=HotelBookingDB
