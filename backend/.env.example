SEPAY_ACCOUNT_NO=0987654321   # Số tài khoản ngân hàng nhận tiền
SEPAY_ACCOUNT_NAME=NGUYEN VAN A # Tên chủ tài khoản ngân hàng (không dấu)
SEPAY_TEMPLATE=qr_only        # Kiểu QR (qr_only, compact, compact2)
